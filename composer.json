{
  "name": "location-chantier/mini-framework",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "vlucas/phpdotenv": "^5.6",
    "symfony/var-dumper": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "App\\Core\\": "src/Core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public",
    "test": "phpunit",
    "migrate": "php scripts/migrate.php",
    "seed": "php scripts/seed.php"
  }
}