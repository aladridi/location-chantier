# ============================================

# PHP_CodeSniffer
/phpcs.xml
/phpcs.xml.dist
/.phpcs-cache

# PHP-CS-Fixer
/.php_cs
/.php_cs.dist
/.php-cs-fixer.cache
/php-cs-fixer.phar

