# ============================================

/phpunit.xml
/phpunit.xml.dist
/phpunit.phar
/tests/_output/
/tests/_support/_generated/
/tests/coverage/
/.phpunit.result.cache
/build/
/clover.xml
/coverage/
/coverage-html/
/coverage.clover
/coverage.xml
/junit.xml
/phpunit-report.xml
/testdox.html
/testdox.txt

