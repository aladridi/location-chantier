# ============================================
# Fichier .gitignore pour projet PHP 8.4
# Location de matériel de chantier
# ============================================

# ============================================
# 1. Dépendances PHP (Composer)
# ============================================
/vendor/
composer.lock
composer.phar

# ============================================
# 2. Environnement et configuration
# ============================================
.env
.env.local
.env.*.local
.env.backup
.env.*.backup
.env.production
.env.staging
.env.testing

# Fichiers de configuration sensibles
/config/config.local.php
/config/parameters.php
/config/secrets.php

# ============================================
# 3. Cache et logs
# ============================================
/cache/
/logs/
/var/cache/
/var/logs/
/var/sessions/
/var/tmp/
*.log
*.cache
*.tmp
*.temp

# Logs spécifiques
access.log
error.log
debug.log
app.log
*.log.*

# ============================================
# 4. IDE et éditeurs de texte
# ============================================

# PHPStorm / IntelliJ IDEA
/.idea/
/*.iml
/.phpstorm.meta/
/.idea/workspace.xml
/.idea/tasks.xml
/.idea/dictionaries/
/.idea/dataSources.ids
/.idea/dataSources.xml
/.idea/sqlDataSources.xml
/.idea/caches/build_file_checksums.ser
/.idea/httpRequests/
/.idea/php.xml
/.idea/phpunit.xml
/.idea/vcs.xml
/.idea/modules.xml
/.idea/*.iml

# Visual Studio Code
/.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace
.history/
*.vsix
/.vscode/launch.json
/.vscode/tasks.json

# Sublime Text
*.sublime-project
*.sublime-workspace
.sublime/

# Atom
.atom/
*.atom-project

# Eclipse
/.project
/.classpath
/.settings/
*.buildpath
*.project

# NetBeans
/nbproject/
/*.nbproject

# Vim
*.swp
*.swo
*.un~
*.~*
.*.swp
.*.swo

# ============================================
