# ============================================
# 8. Outils de build et déploiement
# ============================================

# Docker
/docker-compose.override.yml
/docker-compose.local.yml
/.dockerignore
/Dockerfile
/docker/
!docker/Dockerfile
.docker/
*.docker

# CI/CD
/.github/workflows/*.local.yml
/.gitlab-ci.local.yml
/.travis.yml.local
/buildpacks/

# Makefile
Makefile.local

# ============================================
# 9. Assets et fichiers uploadés
# ============================================

# Uploads
/public/files/
/uploads/
/media/
/files/
/import/
/export/
/temp/

# Fonts et assets générés
/public/dist/


# ============================================
# 10. Base de données
# ============================================

# SQLite
*.sqlite
*.sqlite3
*.db
*.db3

# Dumps SQL
*.sql
*.dump
*.backup
/*.sql.gz
/*.sql.zip

# Migrations générées (si non versionnées)
/migrations/version_*.php
/migrations/*.sql.generated

# Doctrine
/doctrine_migrations/
/doctrine_schema.dump

# ============================================
# 11. Archives et packages
# ============================================

*.zip
*.tar.gz
*.tgz
*.rar
*.7z
*.jar
*.war
*.ear
*.phar

# ============================================
# 12. Dépendances JavaScript/Node.js (si utilisé)
# ============================================

/node_modules/
/npm-debug.log
/npm-debug.log.*
/yarn-debug.log*
/yarn-error.log*
/package-lock.json
/yarn.lock
/.pnpm-debug.log
/.pnpm-store/

# ============================================
# 13. Outils divers
# ============================================

# Composer local
/composer.lock

# Téléchargements temporaires
/tmp/
/downloads/
/var/tmp/

# Profiling
/cachegrind.out*
/xdebug.*.log
/xdebug.*.trace
/*.prof

# Mail catcher
/mailhog/
/mailcatcher/

# Sessions PHP
/sessions/

# ============================================
# 14. Fichiers spécifiques au projet
# ============================================

# Fichiers de seed (données de test)
/database/seeds/*.local.php
/data/fixtures/

# Documentation générée
/docs/api/
/docs/coverage/
/docs/html/

# Backups du projet
*.backup.*
*-backup
backup_*/

# Fichiers de verrouillage du framework maison
/.lock
/.pid

# ============================================
# 15. Fichiers de développement
# ============================================

# Environnement de développement local
/.env.dev
/.env.local.dev
/.env.test

# Fichiers de routeur Symfony (si utilisé plus tard)
/.routing.yml.local

# Fichiers de configuration Apache/Nginx
/.htaccess.local
/nginx.conf.local
/vhost.conf.local

# ============================================
# 16. Fichiers de sécurité
# ============================================

# Certificats SSL
*.pem
*.crt
*.key
*.p12
*.pfx
*.csr
*.cert
*.private
*.pub

# ============================================
# EXCEPTIONS (fichiers à garder malgré tout)
# ============================================

# Garder .gitkeep dans les dossiers vides
!.gitkeep
!.keep

# Garder les fichiers d'exemple d'environnement
!.env.example
!.env.dist
!.env.testing.example

# Garder les fichiers de configuration d'exemple
!/config/*.example.php
!/config/*.dist.php

# Garder les fixtures d'exemple
!/data/fixtures/*.example.*

# ============================================
# 17. Fichiers propres à ton projet
# ============================================

# Fichiers de debug du projet
/project.log
/project.debug

# Téléchargements du projet
/downloads/

# Fichiers temporaires du routeur
/router.cache
/routes.cache

# Profilage personnalisé
/profiling/
/*.profile

# ============================================
# 18. Messages et documents temporaires
# ============================================

# Documents de travail
/*.md.tmp
/*.txt.tmp
/*.doc.tmp
/todo.md.local
/notes.md.local

# ============================================
# 19. Fichiers de session et authentification
# ============================================

/sessions/
/session/
/sess_*

# ============================================
# 20. Autres
# ============================================

# Fichiers de verrouillage générés par PHP
*.lck
*.lock

# Fichiers de configuration de PHP
/php.ini.local
/php-cli.ini.local

# Fichiers de déploiement
/deploy/
/deployments/
/deployment/

# Fichiers de configuration d'outils
/*.tool
/*.tools
/.tool-versions

# Histoire de terminal
/.bash_history
/.zsh_history
/.history

# Fichiers de récupération de données
/recovery/
/restore/

# Fichiers de cache de bibliothèque
/.cache/

# ============================================
# UPLOADS - Ne pas versionner les images
# ============================================

# Dossier principal d'upload
/uploads/
/public/uploads/

# Sous-dossiers spécifiques
/public/uploads/equipment/
/public/uploads/equipment/original/
/public/uploads/equipment/large/
/public/uploads/equipment/medium/
/public/uploads/equipment/thumbnail/

# Tous les fichiers images
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.svg
*.ico

# Fichiers temporaires d'upload
*.tmp
*.temp

# ✅ Garder les fichiers .gitkeep pour la structure
!uploads/.gitkeep
!public/uploads/.gitkeep
!public/uploads/equipment/.gitkeep
!public/uploads/equipment/original/.gitkeep
!public/uploads/equipment/large/.gitkeep
!public/uploads/equipment/medium/.gitkeep
!public/uploads/equipment/thumbnail/.gitkeep
